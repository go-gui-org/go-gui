{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "schedule:weekly",
    ":dependencyDashboard"
  ],
  "labels": ["dependencies"],
  "postUpdateOptions": ["gomodTidy"],
  "packageRules": [
    {
      "description": "Group Go module updates into a single PR",
      "matchManagers": ["gomod"],
      "groupName": "Go modules",
      "groupSlug": "go-modules"
    },
    {
      "description": "Group GitHub Actions updates into a single PR",
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions",
      "groupSlug": "github-actions",
      "pinDigests": true
    }
  ],
  "customManagers": [
    {
      "description": "Update golangci-lint version in Makefile",
      "customType": "regex",
      "fileMatch": ["^Makefile$"],
      "matchStrings": [
        "LINT_VERSION\\s*=\\s*(?<currentValue>v\\d+\\.\\d+\\.\\d+)"
      ],
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "golangci/golangci-lint",
      "extractVersionTemplate": "^v(?<version>.*)$",
      "versioningTemplate": "semver"
    }
  ]
}
